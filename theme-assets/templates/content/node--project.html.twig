{#
/**
 * @file
 * Project recipe — Project node template.
 *
 * A basic page with a link and a thumbnail. Renders the content fields the
 * view display provides (thumbnail, body, link) with minimal, semantic markup.
 *
 * @ingroup themeable
 */
#}
<article{{ attributes }}>

  {{ title_prefix }}
  {% if not page %}
    <h2{{ title_attributes }}>
      <a href="{{ url }}" rel="bookmark">{{ label }}</a>
    </h2>
  {% endif %}
  {{ title_suffix }}

  <div{{ content_attributes }}>
    {{ content }}
  </div>

</article>
